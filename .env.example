# Xcash 自托管环境变量模板
# 使用方式：
# 1. ./init_env.sh（自动生成 .env 并填充随机密钥）
# 2. 执行 docker compose up -d --build

# 域名访问
SITE_DOMAIN=pay.example.com

# 监听地址，默认仅本机
LISTEN_TO=127.0.0.1

# Django / 主应用
# 生产部署必须显式提供稳定 SECRET_KEY，避免容器重建后签名状态漂移。
DJANGO_SECRET_KEY=change-me-with-a-64-char-random-string
# 首次部署且库内不存在管理员时，web 容器会自动创建默认后台账号（用户名固定为 admin）。
DJANGO_DEFAULT_SUPERUSER_PASSWORD=Admin@123456

# 性能档位：low=1c2g，middle=4c8g，high=8c16g；不设置时默认 low。
PERFORMANCE=low

# 主应用数据库口令
# 数据库名、用户和主机由官方 compose 固定管理，这里只保留必须自管的口令。
POSTGRES_PASSWORD=change-me-main-db-password

# 主应用 signer 集成
# 主应用固定通过独立 signer 服务完成地址派生和签名。
SIGNER_SHARED_SECRET=change-me-shared-hmac-secret

# signer 服务
# signer 的 Web 框架密钥、助记词加密密钥和数据库口令必须独立管理。
SIGNER_SECRET_KEY=change-me-signer-secret-key
SIGNER_MNEMONIC_ENCRYPTION_KEY=change-me-mnemonic-encryption-key
SIGNER_POSTGRES_PASSWORD=change-me-signer-db-password

# 可选增强
TRUSTED_PROXY_IPS=
